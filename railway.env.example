# Railway — livia-api production (api.livia-hq.com)
# Copy keys into Railway → Variables. Replace placeholder values before go-live.

# --- Core ---
NODE_ENV=production
LIVIA_DEPLOY_ENV=production
DATABASE_URL=
SUPABASE_DATABASE_URL_DIRECT=

# --- URLs ---
DASHBOARD_URL=https://app.livia-hq.com
MARKETING_URL=https://livia-hq.com
API_PUBLIC_URL=https://api.livia-hq.com
CORS_ALLOWED_ORIGINS=https://app.livia-hq.com,https://livia-hq.com
CLERK_PROXY_URL=https://app.livia-hq.com/api/__clerk

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Sign-up (open public) ---
LIVIA_BETA_SIGNUP_MODE=open

# --- Paid onboarding (Stripe checkout during onboarding) ---
LIVIA_PUBLIC_PAID_ONBOARDING=true
# Partner codes: CODE=plan or CODE=plan:days — e.g. LIVIA-FRIEND=solo (no charge)
LIVIA_COMPLIMENTARY_PROMO_CODES=LIVIA-FRIEND=solo

# --- Stripe (subscriptions + add-ons) ---
# Provision: pnpm stripe:provision (test) or sk_live in .env then pnpm stripe:provision:live
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_SOLO=price_REPLACE_ME
STRIPE_PRICE_STUDIO=price_REPLACE_ME
STRIPE_PRICE_CHAIN=price_REPLACE_ME
STRIPE_PRICE_CHAIR_HOST=price_REPLACE_ME
STRIPE_PRICE_PEER_INSIGHTS=price_REPLACE_ME
STRIPE_PRICE_EVENT_OPERATOR=price_REPLACE_ME
STRIPE_PRICE_RETAIL_PACK=price_REPLACE_ME
STRIPE_ALLOW_PROMOTION_CODES=true

# --- Email (Resend) ---
RESEND_API_KEY=re_REPLACE_ME
RESEND_DEFAULT_FROM=Livia <noreply@livia-hq.com>

# --- SMS (Twilio) — when account approved ---
TWILIO_ACCOUNT_SID=AC_REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_DEFAULT_FROM=+353REPLACE_ME

# --- Guest hub OTP strict mode (production) ---
# LIVIA_STAGING_RELAX_GUEST_OTP not set in prod

# --- Workflows (set false + Inngest keys when ready) ---
WORKFLOWS_DISABLED=true
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Internal ops ---
INTERNAL_OPS_SECRET=REPLACE_ME_LONG_RANDOM
INTERNAL_PORTAL_URL=https://ops.livia-hq.com
INTERNAL_EXEC_PATH=REPLACE_ME_LONG_RANDOM
LIVIA_PLATFORM_EXEC_EMAILS=projectlazarus@livia-hq.com
LIVIA_STAFF_EMAIL_DOMAINS=livia-hq.com
GOLDSPIRE_STAFF_EMAIL_DOMAINS=goldspireventures.com

# --- Optional ---
ANTHROPIC_API_KEY=
SENTRY_DSN_API=
LIVIA_DEMO_ENABLED=false
