{
  "uid": "livia-api-health",
  "title": "Livia API Health",
  "tags": ["livia", "internal-ops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Error log rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"api-server\"} | json | level=\"error\" [5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Recent error lines",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=\"api-server\"} | json | level=\"error\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "5xx responses",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"api-server\"} | json | status >= 500 [5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
