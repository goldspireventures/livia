modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 20645
externalPort = 3000

[[ports]]
localPort = 24839
externalPort = 3002

[[ports]]
localPort = 24840
externalPort = 3003

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY = "pk_test_ZW5vdWdoLW1ha28tNzYuY2xlcmsuYWNjb3VudHMuZGV2JA"
