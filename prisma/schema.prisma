/// Prisma Client (runtime) uses `DATABASE_URL` below.
/// For Supabase **transaction pooler** (PgBouncer, port 6543), use the pooler connection string from the dashboard
/// and append flags on `DATABASE_URL` so the engine uses a single logical client connection pattern Prisma expects:
///   `pgbouncer=true&connection_limit=1`
/// Also include `sslmode=require`. If you see `ENOIDENTIFIER` (no tenant identifier), add a tenant hint:
///   `options=reference%3D<project_ref>`
/// If the URI already contains `?`, join with `&` instead, e.g.
///   `.../postgres?sslmode=require&pgbouncer=true&connection_limit=1&options=reference%3D<project_ref>`
/// Do **not** hardcode credentials or hosts here — set the full URL in `.env` only.
///
/// **IPv6 / direct endpoint:** Supabase’s **direct** host `db.<project-ref>.supabase.co:5432` is often **IPv6-only**.
/// Many home/office networks cannot route IPv6-only endpoints, so **local development** commonly uses the
/// **pooler** hostname (IPv4-compatible proxy) for `DATABASE_URL`.
///
/// **PgBouncer + Migrate:** Prisma Migrate uses advisory locks and DDL patterns that are unreliable through a
/// **transaction-mode** pooler; hangs or failures are common if Migrate shares only the pooled URL. Set
/// `DIRECT_URL` to Supabase’s **direct** connection string (same DB, port 5432) so Migrate and introspection
/// use a non-pooled session while the app keeps using the pooled `DATABASE_URL`.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (generic domain language) ---

enum MembershipRole {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

enum StaffRole {
  PROVIDER
  COORDINATOR
  OTHER
}

enum BookingStatus {
  DRAFT
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum ChannelType {
  EMAIL
  PHONE
  SMS
  EXTERNAL
  OTHER
}

enum PaymentIntentStatus {
  CREATED
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  CANCELED
  FAILED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum PaymentPurpose {
  BOOKING
  DEPOSIT
  INVOICE
  TIP
  SUBSCRIPTION
  OTHER
}

enum EventLevel {
  DEBUG
  INFO
  WARN
  ERROR
  AUDIT
}

enum PaymentAccountStatus {
  PENDING
  ACTIVE
  RESTRICTED
  DISABLED
}

enum NotificationChannel {
  EMAIL
  WEB_PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageLogStatus {
  RECEIVED
  LINKED
  UNMATCHED
  REJECTED
}

// --- Core identity & tenancy ---

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  /// Clerk `user_*` id when using Clerk auth; null for dev-only users or other providers later.
  clerkUserId      String?              @unique
  emailVerifiedAt  DateTime?
  name             String?
  imageUrl         String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @default(now()) @updatedAt

  memberships          BusinessMembership[]
  staff                Staff[]
  events               Event[]               @relation("EventActor")
  webPushSubscriptions WebPushSubscription[]
  notificationLogs     NotificationLog[]    @relation("NotificationRecipient")
  inAppNotifications   InAppNotification[]
  aiInteractions       AIInteraction[]
}

model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  memberships            BusinessMembership[]
  staff                    Staff[]
  services                 Service[]
  staffServiceAssignments  StaffServiceAssignment[]
  customers                Customer[]
  channelIdentities        ChannelIdentity[]
  bookings                 Booking[]
  availabilityRules        AvailabilityRule[]
  timeOffs                 TimeOff[]
  events                   Event[]
  paymentIntentRecords     PaymentIntentRecord[]
  payments                 Payment[]
  paymentAccounts          PaymentAccount[]
  featureFlags             FeatureFlag[]
  notificationLogs         NotificationLog[]
  inAppNotifications       InAppNotification[]
  messageLogs              MessageLog[]
  aiInteractions           AIInteraction[]
}

model BusinessMembership {
  id         String          @id @default(cuid())
  businessId String
  userId     String
  role       MembershipRole
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

// --- Operations ---

model Staff {
  id          String    @id @default(cuid())
  businessId  String
  userId      String?
  firstName   String
  lastName    String?
  displayName String
  email       String?
  phone       String?
  photoUrl    String?
  bio         String?
  role        StaffRole @default(PROVIDER)
  active      Boolean   @default(true)
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  business                 Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user                     User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  serviceAssignments       StaffServiceAssignment[]
  bookings                 Booking[]
  availabilityRules        AvailabilityRule[]
  timeOffs                 TimeOff[]

  @@index([businessId])
  @@index([businessId, userId])
  @@index([businessId, active])
  @@index([businessId, email])
}

model Service {
  id                 String   @id @default(cuid())
  businessId         String
  name               String
  description        String?
  category           String?
  durationMinutes    Int
  basePriceMinorUnits Int?
  currency           String?  @db.VarChar(3)
  imageUrl           String?
  active             Boolean  @default(true)
  sortOrder          Int      @default(0)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  business        Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignments     StaffServiceAssignment[]
  bookings        Booking[]

  @@index([businessId])
  @@index([businessId, active])
}

model StaffServiceAssignment {
  id         String   @id @default(cuid())
  businessId String
  staffId    String
  serviceId  String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@index([businessId])
  @@index([businessId, staffId])
  @@index([businessId, serviceId])
}

model Customer {
  id          String   @id @default(cuid())
  businessId  String
  displayName String
  notes       String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  business           Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  channelIdentities  ChannelIdentity[]
  bookings           Booking[]
  messageLogs        MessageLog[]

  @@index([businessId])
}

model ChannelIdentity {
  id          String       @id @default(cuid())
  businessId  String
  customerId  String?
  channel     ChannelType
  value       String
  verifiedAt  DateTime?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messageLogs MessageLog[]

  @@unique([businessId, channel, value])
  @@index([businessId])
  @@index([customerId])
}

model Booking {
  id             String        @id @default(cuid())
  businessId     String
  customerId     String
  serviceId      String
  staffId        String?
  startsAt       DateTime
  endsAt         DateTime
  status         BookingStatus @default(PENDING)
  notes          String?
  internalNotes  String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt

  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer              Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service               Service                @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff                 Staff?                 @relation(fields: [staffId], references: [id], onDelete: SetNull)
  paymentIntentRecords  PaymentIntentRecord[]
  payments              Payment[]

  @@index([businessId])
  @@index([businessId, startsAt])
  @@index([customerId])
  @@index([staffId])
  @@index([serviceId])
  @@index([staffId, startsAt])
}

model AvailabilityRule {
  id            String    @id @default(cuid())
  businessId    String
  staffId       String
  /// 0 = Sunday .. 6 = Saturday (project convention; document in app)
  weekday       Int
  /// Minutes from local midnight [0, 1440)
  startMinutes  Int
  endMinutes    Int
  timezone      String    @default("UTC")
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  active        Boolean   @default(true)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, staffId])
  @@index([staffId, weekday])
}

model TimeOff {
  id         String   @id @default(cuid())
  businessId String
  staffId    String
  startsAt   DateTime
  endsAt     DateTime
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, staffId, startsAt])
  @@index([staffId, startsAt])
}

model Event {
  id           String     @id @default(cuid())
  /// Null = platform-level event (not tied to a tenant row)
  businessId   String?
  level        EventLevel @default(INFO)
  type         String
  subjectType  String?
  subjectId    String?
  actorUserId  String?
  payload      Json?
  occurredAt   DateTime   @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actor    User?     @relation("EventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([businessId, occurredAt])
  @@index([level, occurredAt])
  @@index([type, occurredAt])
}

// --- Payments ---

model PaymentIntentRecord {
  id                String               @id @default(cuid())
  businessId        String
  bookingId         String?
  provider          String               @default("stripe")
  externalId        String?
  amountMinorUnits  Int
  currency          String               @db.VarChar(3)
  status            PaymentIntentStatus  @default(CREATED)
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @default(now()) @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  payments Payment[]

  /// Uniqueness of (provider, externalId) enforced in app when externalId is set; multiple nulls before confirmation are allowed.
  @@index([provider, externalId])
  @@index([businessId])
  @@index([bookingId])
  @@index([businessId, status])
}

model Payment {
  id                     String          @id @default(cuid())
  businessId             String
  bookingId              String?
  paymentIntentRecordId  String?
  amountMinorUnits       Int
  currency               String          @db.VarChar(3)
  status                 PaymentStatus   @default(PENDING)
  purpose                PaymentPurpose  @default(BOOKING)
  occurredAt             DateTime?
  metadata               Json?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @default(now()) @updatedAt

  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking             Booking?               @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  paymentIntentRecord PaymentIntentRecord?   @relation(fields: [paymentIntentRecordId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([bookingId])
  @@index([paymentIntentRecordId])
  @@index([businessId, status])
}

model PaymentAccount {
  id                 String                 @id @default(cuid())
  businessId         String
  provider           String                 @default("stripe")
  externalAccountId  String
  status             PaymentAccountStatus   @default(PENDING)
  capabilities       Json?
  metadata           Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, provider])
}

model FeatureFlag {
  id         String   @id @default(cuid())
  businessId String
  key        String
  enabled    Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, key])
  @@index([businessId])
}

/// Outbound notification attempts (email, web push) for auditing and retries.
model NotificationLog {
  id                String              @id @default(cuid())
  businessId        String?
  recipientUserId   String?
  channel           NotificationChannel
  status            NotificationStatus  @default(PENDING)
  templateKey       String
  payload           Json?
  /// Redacted target hint (e.g. domain of push endpoint or local-part hash).
  target            String?
  providerMessageId String?
  lastError         String?
  createdAt         DateTime            @default(now())
  sentAt            DateTime?

  business  Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  recipient User?     @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([recipientUserId])
}

model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Staff-facing inbox (owner/admin): survives refresh; independent of push delivery.
model InAppNotification {
  id         String    @id @default(cuid())
  userId     String
  businessId String?
  kind       String
  title      String
  body       String
  href       String?
  payload    Json?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

/// Inbound/outbound messaging audit (T6). No live provider until wired; maps to `ChannelIdentity` + `Customer` when matched.
model MessageLog {
  id                 String           @id @default(cuid())
  businessId         String
  provider           String           @default("unknown")
  direction          MessageDirection @default(INBOUND)
  channel            ChannelType
  /// Normalized handle (e.g. E.164-ish phone, WhatsApp id).
  fromValue          String
  bodyPreview        String
  payload            Json?
  customerId         String?
  channelIdentityId  String?
  status             MessageLogStatus @default(RECEIVED)
  error              String?
  createdAt          DateTime         @default(now())

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  channelIdentity  ChannelIdentity?  @relation(fields: [channelIdentityId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([businessId, channel, fromValue])
}

/// T5 — AI assistive calls (never authoritative). Read-only insights log here; failures must not affect core flows.
model AIInteraction {
  id               String   @id @default(cuid())
  businessId       String?
  userId           String?
  kind             String
  model            String?
  promptSummary    String?
  responseSummary  String?
  error            String?
  durationMs       Int?
  metadata         Json?
  createdAt        DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
}
