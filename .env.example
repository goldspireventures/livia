# Livia — local development (copy to `.env`; never commit `.env`)
# Production API template: railway.env.example
# Full reference: docs/operations/ENV-VARIABLES.md

# --- Required (local) ---
DATABASE_URL=postgresql://livia:livia@localhost:5432/livia
# Optional: production Supabase URL (session pooler :5432 for DDL). Default local ops use DATABASE_URL (staging).
# DATABASE_URL_PROD=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Switch: pnpm db:targets | pnpm db:sync:staging | pnpm db:sync:prod
# Supabase: prefer Session pooler (5432); alias SUPABASE_DATABASE_URL also works in lib/db
CLERK_SECRET_KEY=sk_test_
CLERK_PUBLISHABLE_KEY=pk_test_

# --- API runtime ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=false

# --- Public URLs (production: see railway.env.example) ---
DASHBOARD_URL=http://localhost:5173
MARKETING_URL=http://localhost:5174
INTERNAL_URL=http://localhost:5175
API_PUBLIC_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=

# --- Uploads ---
UPLOAD_DIR=
UPLOAD_MAX_BYTES=10485760

# --- Demo (local only — never enable in production) ---
LIVIA_DEMO_ENABLED=true
LIVIA_DEMO_PASSWORD=LiviaDemo2026!
# W1 marketing /demo gate — signs book-demo access tokens (min 32 chars)
LIVIA_MARKETING_DEMO_GATE_SECRET=dev-marketing-demo-gate-secret-change-me
# Optional founder/E2E bypass — /demo?key=<this value>
# LIVIA_MARKETING_DEMO_GATE_BYPASS_KEY=

# --- Internal ops (local portal + API routes) ---
INTERNAL_OPS_SECRET=change-me-long-random
INTERNAL_CRON_SECRET=change-me-long-random-different
INTERNAL_PORTAL_URL=http://localhost:5175
# INTERNAL_EXEC_PATH=l7-local-dev-slug
LIVIA_PLATFORM_EXEC_EMAILS=projectlazarus@livia.io

# --- Partner / API keys (dev) ---
PARTNER_API_KEY=dev-partner-key-change-me
API_KEY_PEPPER=dev-pepper-change-in-production

# --- Optional integrations (unset = feature off) ---
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_CHAIN=
STRIPE_PRICE_CHAIR_HOST=
STRIPE_PRICE_PEER_INSIGHTS=
RESEND_API_KEY=
RESEND_DEFAULT_FROM=Livia <onboarding@resend.dev>
SUPPORT_INBOX_EMAIL=support@livia.io
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=livia_meta_verify_dev
META_DEV_SIMULATE=true
WORKFLOWS_DISABLED=true
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
SENTRY_DSN_API=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=

# --- Local observability stack (docker/observability) ---
LOKI_PUSH_URL=
LOKI_LABELS=service=api-server
GRAFANA_URL=http://127.0.0.1:3000
OPENOBSERVE_URL=
OPENOBSERVE_ORG=default
OPENOBSERVE_USER=
OPENOBSERVE_PASSWORD=
OPENOBSERVE_STREAM=default

# --- E2E / Playwright only (not used by the API in production) ---
E2E_API_BASE=http://127.0.0.1:3000
E2E_DASHBOARD_BASE=http://127.0.0.1:5173
E2E_MARKETING_URL=http://127.0.0.1:5174
E2E_DEMO_SLUG=luxe-salon-spa
E2E_PARTNER_API_KEY=dev-partner-key-change-me

# Per-app: artifacts/livia-dashboard|.env.example, livia-mobile, livia-marketing, livia-internal
