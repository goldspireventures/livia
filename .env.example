# Livia — local development & E2E (copy to `.env` at repo root; never commit `.env`)
# See docs/testing/MANUAL-WALKTHROUGH-BETA.md for the founder walkthrough.

# --- Required ---
DATABASE_URL=postgresql://livia:livia@localhost:5432/livia
# Supabase: use Session pooler URL (port 5432), not db.*.supabase.co if DNS fails on Windows
CLERK_SECRET_KEY=sk_test_
CLERK_PUBLISHABLE_KEY=pk_test_
# Production (Railway): public dashboard origin for Clerk proxy — required when /api is rewritten via Vercel
# CLERK_PROXY_URL=https://app.livia-hq.com/api/__clerk

# --- API ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# Optional: duplicate JSON logs to local Loki (see docker/observability + scripts/observability-up.mjs)
LOKI_PUSH_URL=
LOKI_LABELS=service=api-server
# Internal portal log search (defaults from LOKI_PUSH_URL if unset)
LOKI_QUERY_BASE_URL=
GRAFANA_LOCAL_URL=http://127.0.0.1:3000
GRAFANA_EMBED_BASE_URL=http://127.0.0.1:3000
# Optional OpenObserve (hosted log analytics)
OPENOBSERVE_URL=
OPENOBSERVE_ORG=default
OPENOBSERVE_USER=
OPENOBSERVE_PASSWORD=
OPENOBSERVE_STREAM=default
TRUST_PROXY=false
# Production: comma-separated origins, e.g. https://app.livia-hq.com,https://livia-hq.com
CORS_ALLOWED_ORIGINS=
DASHBOARD_BASE_URL=http://localhost:5173
DASHBOARD_PUBLIC_URL=http://localhost:5173
MARKETING_PUBLIC_URL=http://localhost:5174
INTERNAL_PUBLIC_URL=http://localhost:5175
PUBLIC_BASE_URL=http://localhost:3000
# Local image uploads (served at /uploads/…); optional absolute path
UPLOAD_DIR=
UPLOAD_MAX_BYTES=10485760

# Deep links (API → dashboard / Clerk; optional for internal ops tenant cards)
TENANT_DASHBOARD_URL=http://localhost:5173
CLERK_DASHBOARD_USER_URL=

# --- Demo portal (local / beta) ---
LIVIA_DEMO_ENABLED=true
LIVIA_DEMO_PASSWORD=LiviaDemo2026!

# --- E2E ---
E2E_API_BASE=http://127.0.0.1:3000
E2E_DASHBOARD_BASE=http://127.0.0.1:5173
E2E_MARKETING_URL=http://127.0.0.1:5174
E2E_DEMO_SLUG=luxe-salon-spa

# Per-artifact env (copy from):
#   artifacts/livia-dashboard/.env.example
#   artifacts/livia-marketing/.env.example
#   artifacts/livia-internal/.env.example
#   artifacts/livia-mobile/.env.example

# --- Internal ops (smoke + livia-internal) ---
INTERNAL_OPS_SECRET=change-me-long-random
INTERNAL_CRON_SECRET=change-me-long-random-different
# Internal portal Sentry deep links (optional)
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=

# --- Partner / API keys (dev) ---
PARTNER_API_KEY=dev-partner-key-change-me
E2E_PARTNER_API_KEY=dev-partner-key-change-me
API_KEY_PEPPER=dev-pepper-change-in-production

# --- Liv AI (optional — public chat E2E skips if unset) ---
ANTHROPIC_API_KEY=
# API_COMPRESS=true  # gzip JSON in dev (on automatically in production)

# --- Stripe (optional — checkout smoke skips if unset) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_CHAIN=
STRIPE_PRICE_CHAIR_HOST=
STRIPE_PRICE_PEER_INSIGHTS=

# --- Email (optional — support ack + booking mail; degrades gracefully) ---
RESEND_API_KEY=
RESEND_DEFAULT_FROM=Livia <onboarding@resend.dev>
# Inbox copy for new support tickets (defaults to support@livia.io)
SUPPORT_INBOX_EMAIL=support@livia.io

# --- Messaging (optional — degrades gracefully) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=livia_meta_verify_dev
META_DEV_SIMULATE=true
WORKFLOWS_DISABLED=true

# --- Web Push (optional — desktop background alerts) ---
# npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@livia.io
# EXPO_ACCESS_TOKEN=  # optional; improves Expo push delivery

# --- Observability (optional) ---
SENTRY_DSN_API=
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_DSN=
