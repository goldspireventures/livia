# Copy to .env and fill in values. Never commit .env.

# Required — PostgreSQL (Supabase: use pooler URL + pgbouncer flags per prisma/schema.prisma header)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Recommended for Prisma Migrate (direct connection, port 5432; avoids PgBouncer DDL issues)
# DIRECT_URL="postgresql://USER:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Optional — public site URL for links in emails etc.
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional — Clerk (required for protected routes). When unset, protected pages/APIs will reject requests.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Optional — Stripe (Phase 7+); leave unset until PSP work is wired
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Optional — public API rate limit (requests per IP per rolling minute). Default 120. Set to 0 to disable.
# PUBLIC_API_RATE_LIMIT_PER_IP_PER_MINUTE=120

# Optional — Customer booking emails (off by default). In-app + push cover staff; set true when Resend is ready.
# NOTIFICATION_EMAIL_ENABLED=true
# RESEND_API_KEY=
# NOTIFICATION_EMAIL_FROM="Livia <bookings@yourdomain.com>"

# Optional — Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
# Use the same public key in the browser:
# VAPID_SUBJECT="mailto:you@example.com"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- T6 messaging inbound (optional shared secret for /api/webhooks/messaging) ---
# MESSAGING_INBOUND_SECRET=

# --- T5 AI (optional; health endpoint degrades without key) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Capacitor dev (optional; point device/simulator at your machine) ---
# CAPACITOR_SERVER_URL=http://192.168.1.10:3000
