{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack enable && corepack prepare pnpm@10.33.0 --activate && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/livia-dashboard run build",
  "outputDirectory": "artifacts/livia-dashboard/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.livia-hq.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "PORT": "5173",
    "BASE_PATH": "/"
  }
}
