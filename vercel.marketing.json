{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack enable && corepack prepare pnpm@10.33.0 --activate && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/livia-marketing run build",
  "outputDirectory": "artifacts/livia-marketing/dist/public",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "env": {
    "PORT": "5174",
    "BASE_PATH": "/"
  }
}
