# Copy to `.env` in this folder (never commit `.env`)

# Same Clerk publishable key as repo root / dashboard
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_

# Production device testing (real Resend OTP + strict guest auth):
#   pnpm dev:prod          — simulator / same-network device
#   pnpm dev:device:prod   — physical device (Metro LAN + prod API)
# Copy `.env.prod.example` → `.env` and set pk_live_ Clerk key.

# Physical device local API: LAN IP, e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000

# Web app for onboarding continue + public booking tests
EXPO_PUBLIC_DASHBOARD_URL=http://127.0.0.1:5173

# G1 wedge card photos (defaults to staging app when API is LAN/localhost)
# EXPO_PUBLIC_GATEWAY_ASSETS_URL=https://app.staging.livia-hq.com

# Marketing site for public booking links (production: https://livia-hq.com)
# EXPO_PUBLIC_MARKETING_URL=https://livia-hq.com
# EXPO_PUBLIC_PLATFORM_EXEC_EMAILS=projectlazarus@livia.io

# Production app (default) — demo gateway off. Enable only for internal walkthroughs:
# EXPO_PUBLIC_DEMO_LOGIN=true
