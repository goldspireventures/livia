# Copy to `.env` in this folder (never commit `.env`)

# Same Clerk publishable key as repo root / dashboard
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_

# Physical device: LAN IP of your dev machine, e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000

# Web app for onboarding continue + public booking tests
EXPO_PUBLIC_DASHBOARD_URL=http://127.0.0.1:5173

# Marketing site for public booking links (production: https://livia-hq.com)
# EXPO_PUBLIC_MARKETING_URL=https://livia-hq.com
# EXPO_PUBLIC_PLATFORM_EXEC_EMAILS=projectlazarus@livia.io

# Optional: demo gateway on device builds
# EXPO_PUBLIC_DEMO_LOGIN=true
