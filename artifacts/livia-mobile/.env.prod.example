# Mobile → production stack (copy to `.env` for device testing against live API)
# Do not commit `.env`.

# Production Clerk publishable key (pk_live_… from Clerk dashboard)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_

EXPO_PUBLIC_API_BASE_URL=https://api.livia-hq.com
EXPO_PUBLIC_DASHBOARD_URL=https://app.livia-hq.com
EXPO_PUBLIC_MARKETING_URL=https://livia-hq.com
EXPO_PUBLIC_GATEWAY_ASSETS_URL=https://app.livia-hq.com

# Production app — no demo shortcuts
EXPO_PUBLIC_DEMO_LOGIN=false

# Optional
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_PLATFORM_EXEC_EMAILS=projectlazarus@livia.io
