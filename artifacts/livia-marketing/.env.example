# Copy to `.env` in this folder (never commit `.env`)

VITE_API_BASE_URL=http://127.0.0.1:3000
# Owner app — sign-in/demo links derive from this (production: https://app.livia-hq.com)
VITE_DASHBOARD_URL=http://127.0.0.1:5173
# Optional overrides (default: {VITE_DASHBOARD_URL}/demo and /sign-in)
# VITE_DASHBOARD_DEMO_URL=
# VITE_DASHBOARD_SIGN_IN_URL=
# Production marketing origin (legal links default to {VITE_MARKETING_URL}/legal)
# VITE_MARKETING_URL=https://livia-hq.com
# VITE_LEGAL_BASE_URL=https://livia-hq.com/legal
# VITE_DASHBOARD_SIGN_UP_URL=https://app.livia-hq.com/sign-up
