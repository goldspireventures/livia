# Copy to `.env` in this folder (never commit `.env`)
# livia.io local dev — port 5174 (see repo-root `.env.example` for API + Clerk)

# Where "Try demo" / founder CTAs point (dashboard demo launcher)
VITE_DASHBOARD_DEMO_URL=http://127.0.0.1:5173/demo
VITE_DASHBOARD_SIGN_IN_URL=http://127.0.0.1:5173/sign-in

# Live status page probes API health (optional — page works without it)
VITE_API_BASE_URL=http://127.0.0.1:3000

# Analytics (optional)
VITE_PLAUSIBLE_DOMAIN=

# Vite dev server (default 5174)
PORT=5174
BASE_PATH=/
