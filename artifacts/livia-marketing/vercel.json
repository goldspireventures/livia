{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && corepack enable && corepack prepare pnpm@10.33.0 --activate && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/livia-marketing run build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.staging.livia-hq.com/api/:path*",
      "has": [{ "type": "host", "value": "staging.livia-hq.com" }]
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.livia-hq.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "PORT": "5174",
    "BASE_PATH": "/"
  }
}
