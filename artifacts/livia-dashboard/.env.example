# Copy to `.env` in this folder (never commit `.env`)
# Use the same Clerk app as repo-root `.env`

VITE_CLERK_PUBLISHABLE_KEY=pk_test_
# Production (Vercel): pk_live_ + Clerk CNAME clerk.livia-hq.com (see Clerk → Domains). Do not use proxy unless needed.
# VITE_CLERK_USE_PROXY=true  # only if skipping CNAME and using app.livia-hq.com/api/__clerk on Railway
VITE_API_BASE_URL=http://127.0.0.1:3000
# Legal + marketing links in settings (production: https://livia-hq.com)
# VITE_MARKETING_URL=https://livia-hq.com
# Exec handoff (projectlazarus@livia.io → ops console)
# VITE_INTERNAL_PORTAL_URL=http://127.0.0.1:5175
# VITE_INTERNAL_EXEC_PATH=l7-set-long-random-slug
# VITE_PLATFORM_EXEC_EMAILS=projectlazarus@livia.io

# Immersive portal onboarding on /onboarding (test first at /dev/onboarding-preview)
# VITE_ONBOARDING_PORTAL_EXPERIENCE=true

# Onboarding videos (Loom, YouTube, Vimeo, or .mp4) — see docs/gtm/loom-onboarding-1.md
# VITE_ONBOARDING_VIDEO_WELCOME=
# VITE_ONBOARDING_VIDEO_CHANNELS=
# VITE_ONBOARDING_VIDEO_LIV=
# VITE_ONBOARDING_VIDEO_TOUR=

# Web Push (match repo-root VAPID_PUBLIC_KEY)
# VITE_VAPID_PUBLIC_KEY=
