# Vercel staging dashboard (app.staging.livia-hq.com)
# Copy values into Vercel → Environment Variables (Preview/Production on staging project).
#
# Build-only (Vercel → optional; vite defaults work if unset):
# PORT=5173
# BASE_PATH=/

VITE_LIVIA_DEPLOY_ENV=staging
VITE_CLERK_PUBLISHABLE_KEY=pk_test_
VITE_API_BASE_URL=https://api.staging.livia-hq.com
VITE_MARKETING_URL=https://staging.livia-hq.com
VITE_DEMO_LOGIN=true

# Portal onboarding on /onboarding (default ON on staging; set false to disable)
VITE_ONBOARDING_PORTAL_EXPERIENCE=true

# Optional onboarding videos
# VITE_ONBOARDING_VIDEO_WELCOME=

# Exec handoff (optional on staging)
# VITE_INTERNAL_PORTAL_URL=https://ops.livia-hq.com
# VITE_INTERNAL_EXEC_PATH=
# VITE_PLATFORM_EXEC_EMAILS=projectlazarus@livia-hq.com
# VITE_LIVIA_STAFF_EMAIL_DOMAINS=livia-hq.com
# VITE_GOLDSPIRE_STAFF_EMAIL_DOMAINS=goldspireventures.com
