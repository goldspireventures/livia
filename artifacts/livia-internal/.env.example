# Copy to `.env` in this folder (never commit `.env`)
# Internal ops UI — port 5175. Secret is NOT stored here; paste in the app UI at runtime.

# API proxy target (must match repo-root PORT, default 3000)
INTERNAL_API_PROXY=http://127.0.0.1:3000

# Deep links in founder cockpit (optional; matches API DASHBOARD_URL)
VITE_DASHBOARD_URL=http://127.0.0.1:5173

# Must match repo-root `.env` — paste this value into http://localhost:5175 on first load:
# INTERNAL_OPS_SECRET=change-me-long-random
