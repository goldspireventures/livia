# Copy to `.env` in this folder (never commit `.env`)
# Internal ops UI — port 5175. Secret is NOT stored here; paste in the app UI at runtime.

# API proxy target (must match repo-root PORT, default 3000)
INTERNAL_API_PROXY=http://127.0.0.1:3000

# Deep links in exec command center (optional; matches API DASHBOARD_URL)
VITE_DASHBOARD_URL=http://127.0.0.1:5173

# Secret path for exec overview — set a long random slug before any public deploy.
# Local dev: leave unset (overview at /). Production: e.g. l7-your-random-slug-here
# VITE_INTERNAL_EXEC_PATH=l7-change-me-before-deploy

# Must match repo-root `.env` — paste on first load at http://localhost:5175
# INTERNAL_OPS_SECRET=change-me-long-random
# VITE_INTERNAL_PORTAL_URL=http://127.0.0.1:5175
# VITE_INTERNAL_EXEC_PATH=l7-set-long-random-slug
# VITE_PLATFORM_EXEC_EMAILS=projectlazarus@livia-hq.com
# VITE_LIVIA_STAFF_EMAIL_DOMAINS=livia-hq.com
# VITE_GOLDSPIRE_STAFF_EMAIL_DOMAINS=goldspireventures.com
