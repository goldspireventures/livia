# Railway — livia-api STAGING (separate service from prod)
# Paste into Railway → Variables for api.staging.livia-hq.com only.

NODE_ENV=production
DATABASE_URL=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
DASHBOARD_URL=https://app.staging.livia-hq.com
MARKETING_URL=https://staging.livia-hq.com
API_PUBLIC_URL=https://api.staging.livia-hq.com
CORS_ALLOWED_ORIGINS=https://app.staging.livia-hq.com,https://staging.livia-hq.com,https://livia-hq.com
CLERK_PROXY_URL=https://app.staging.livia-hq.com/api/__clerk

# Staging-only — safe to enable (NODE_ENV=production on Railway; LIVIA_DEPLOY_ENV=staging unlocks demo)
LIVIA_DEMO_ENABLED=true
LIVIA_DEMO_ALLOW_IN_PRODUCTION=false
# W1 marketing /demo concierge — HMAC keys for book-demo links
LIVIA_MARKETING_DEMO_GATE_SECRET=
LIVIA_MARKETING_DEMO_GATE_BYPASS_KEY=
LIVIA_BETA_SIGNUP_MODE=open
LIVIA_DEPLOY_ENV=staging

# Staging QA relaxations (default ON — set LIVIA_STAGING_RELAXED=false to disable all)
LIVIA_STAGING_RELAXED=true
# Guest hub OTP: bypass (magic 000000) | dev (show code) | strict (real SMS flow)
LIVIA_STAGING_RELAX_GUEST_OTP=bypass
# Guest phone: loose (short test numbers) | strict (E.164 only)
LIVIA_STAGING_RELAX_GUEST_PHONE=loose
# Optional override for magic OTP (default 000000)
# LIVIA_STAGING_GUEST_OTP_MAGIC=000000
# Skip platform legal gate during staging QA
# LIVIA_STAGING_RELAX_LEGAL_GATE=true

# Cockpit: prod API can point at this URL for “staging exists”
# API_STAGING_URL=https://api.staging.livia-hq.com

INTERNAL_OPS_SECRET=
INTERNAL_PORTAL_URL=https://ops.livia-hq.com
INTERNAL_EXEC_PATH=l7-set-long-random-slug
LIVIA_PLATFORM_EXEC_EMAILS=projectlazarus@livia-hq.com
LIVIA_STAFF_EMAIL_DOMAINS=livia-hq.com
GOLDSPIRE_STAFF_EMAIL_DOMAINS=goldspireventures.com

# Optional — same as prod when testing integrations on staging
# STRIPE_SECRET_KEY=
# RESEND_API_KEY=
# ANTHROPIC_API_KEY=
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
